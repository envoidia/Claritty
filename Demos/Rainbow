#!/usr/bin/env -S dotnet --

using System.IO.MemoryMappedFiles;

string path = "/dev/shm/ClarittyGraphicsLower";

int width = 1920;
int height = 1080;
long size = (long) width * height * 4;

using MemoryMappedFile mmf = MemoryMappedFile.CreateFromFile(path, FileMode.Open, null,
    size, MemoryMappedFileAccess.ReadWrite);
using MemoryMappedViewAccessor accessor = mmf.CreateViewAccessor();

byte[] pixels = new byte[size];
int frame = 0;

while (true)
{
    generateRainbowFrame(pixels, width, height, frame);

    accessor.WriteArray(0, pixels, 0, pixels.Length);

    frame++;
    Thread.Sleep(16);
}

static void generateRainbowFrame(byte[] pixels, int width, int height, int frame)
{
    int stride = width * 4;

    for (int y = 0; y < height; y++)
    {
        for (int x = 0; x < width; x++)
        {
            int i = y * stride + x * 4;

            double hue = (x * 360.0 / width) + (y * 180.0 / height) + (frame * 2.0);
            hue %= 360;

            (byte r, byte g, byte b) = hsvToRgb(hue, 1.0, 1.0);

            pixels[i + 0] = r;
            pixels[i + 1] = g;
            pixels[i + 2] = b;
            pixels[i + 3] = 255;
        }
    }
}

static (byte r, byte g, byte b) hsvToRgb(double h, double s, double v)
{
    double c = v * s;
    double x = c * (1 - Math.Abs((h / 60) % 2 - 1));
    double m = v - c;

    double r1, g1, b1;

    if (h < 60)
    {
        r1 = c;
        g1 = x;
        b1 = 0;
    }
    else if (h < 120)
    {
        r1 = x;
        g1 = c;
        b1 = 0;
    }
    else if (h < 180)
    {
        r1 = 0;
        g1 = c;
        b1 = x;
    }
    else if (h < 240)
    {
        r1 = 0;
        g1 = x;
        b1 = c;
    }
    else if (h < 300)
    {
        r1 = x;
        g1 = 0;
        b1 = c;
    }
    else
    {
        r1 = c;
        g1 = 0;
        b1 = x;
    }

    return (
        (byte) ((r1 + m) * 255),
        (byte) ((g1 + m) * 255),
        (byte) ((b1 + m) * 255)
    );
}
