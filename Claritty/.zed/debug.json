[
    {
        "label": "Debug .NET Core App",
        "adapter": "netcoredbg",
        "request": "launch",
        "program": "${ZED_WORKTREE_ROOT}/Claritty/bin/Debug/net10.0/Claritty",
        "cwd": "${ZED_WORKTREE_ROOT}",
        "build": {
            "command": "dotnet",
            "args": [
                "build",
                "${ZED_WORKTREE_ROOT}/Claritty/Claritty.csproj",
                "-p:Configuration=Debug",
                "-p:TargetFramework=net10.0",
            ],
        },
    },
]
